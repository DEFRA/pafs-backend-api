{
  "name": "pafs-backend-api",
  "version": "0.0.0",
  "description": "This service provides RESTful APIs for managing flood and coastal erosion risk management projects.",
  "main": "src/index.js",
  "type": "module",
  "engines": {
    "node": ">=22.16.0"
  },
  "scripts": {
    "dev": "NODE_ENV=development npm run server:watch",
    "dev:debug": "NODE_ENV=development npm run server:debug",
    "docker:dev": "npm run dev",
    "format": "prettier --write \"**/*.{cjs,js,json,md}\"",
    "format:check": "prettier --check \"**/*.{cjs,js,json,md}\"",
    "git:pre-commit-hook": "npm run format:check && npm run lint && npm test",
    "lint": "eslint --cache --cache-strategy content \"**/*.{cjs,js}\"",
    "lint:fix": "npm run lint -- --fix",
    "postinstall": "npm run setup:husky && npm run prisma:generate",
    "prisma:generate": "prisma generate",
    "prisma:format": "prisma format",
    "prisma:validate": "prisma validate",
    "prisma:db:pull": "node src/plugins/database/helpers/prisma-db-pull.js",
    "server:debug": "nodemon --inspect-brk=0.0.0.0 --ext js,json --legacy-watch ./src",
    "server:watch": "nodemon --inspect=0.0.0.0 --ext js,json --legacy-watch ./src",
    "setup:husky": "node -e \"try { (await import('husky')).default() } catch (e) { if (e.code !== 'ERR_MODULE_NOT_FOUND') throw e }\" --input-type module",
    "start": "NODE_ENV=production node --use-strict .",
    "test": "cross-env TZ=UTC vitest run --coverage",
    "test:watch": "TZ=UTC vitest"
  },
  "author": "Defra DDTS",
  "license": "OGL-UK-3.0",
  "dependencies": {
    "@aws-sdk/client-s3": "3.1031.0",
    "@aws-sdk/client-sqs": "3.1031.0",
    "@aws-sdk/credential-providers": "3.1031.0",
    "@aws-sdk/rds-signer": "3.1031.0",
    "@aws-sdk/s3-request-presigner": "3.1031.0",
    "@defra/cdp-auditing": "0.6.0",
    "@defra/hapi-secure-context": "0.4.0",
    "@defra/hapi-tracing": "1.30.0",
    "@elastic/ecs-pino-format": "1.5.0",
    "@hapi/boom": "10.0.1",
    "@hapi/hapi": "21.4.8",
    "@hapi/inert": "7.1.0",
    "@hapi/vision": "7.0.3",
    "@prisma/adapter-pg": "7.7.0",
    "@prisma/client": "7.7.0",
    "adm-zip": "0.5.17",
    "aws-embedded-metrics": "4.2.1",
    "aws4": "1.13.2",
    "bcrypt": "6.0.0",
    "convict": "6.2.5",
    "convict-format-with-validator": "6.2.0",
    "exceljs": "4.4.0",
    "global-agent": "4.1.3",
    "hapi-auth-jwt2": "11.0.0",
    "hapi-pino": "13.0.0",
    "hapi-pulse": "3.0.1",
    "hapi-swagger": "17.3.2",
    "https-proxy-agent": "9.0.0",
    "joi": "18.1.2",
    "jsonwebtoken": "9.0.3",
    "mailchecker": "6.0.20",
    "node-cron": "4.2.1",
    "node-fetch": "3.3.2",
    "notifications-node-client": "8.3.2",
    "pg": "8.20.0",
    "pino": "10.3.1",
    "pino-pretty": "13.1.3",
    "prisma": "7.7.0",
    "sqs-consumer": "9.1.0",
    "undici": "8.1.0"
  },
  "devDependencies": {
    "@babel/core": "7.29.0",
    "@babel/preset-env": "7.29.2",
    "@vitest/coverage-v8": "4.1.4",
    "autoprefixer": "10.5.0",
    "cross-env": "10.1.0",
    "eslint": "9.39.4",
    "husky": "9.1.7",
    "neostandard": "0.13.0",
    "nodemon": "3.1.14",
    "npm-run-all": "4.1.5",
    "prettier": "3.8.3",
    "vitest": "4.1.4",
    "vitest-fetch-mock": "0.4.5"
  },
  "overrides": {
    "hapi-swagger": {
      "joi": "$joi"
    },
    "@prisma/config": {
      "effect": "3.21.0"
    },
    "hono": "4.12.14",
    "@hono/node-server": "1.19.13",
    "minimatch": "10.2.4",
    "fast-xml-parser": "5.5.9"
  }
}
