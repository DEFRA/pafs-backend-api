<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

  <changeSet id="5-003-nfm-measures-unique-constraint" author="migration-team">
    <comment>
      Add unique constraint on (project_id, measure_type) in pafs_core_nfm_measures.
      The existing single-column idx_nfm_measures_project_id index is dropped because the
      new compound unique index covers project_id as a left-prefix lookup.
      idx_nfm_measures_type is retained for queries filtered by measure_type alone.
      This changeset runs before data migration so the table is empty.
    </comment>

    <!-- Drop the single-column project_id index — made redundant by the compound unique below -->
    <dropIndex indexName="idx_nfm_measures_project_id"
               tableName="pafs_core_nfm_measures"/>

    <!-- Add unique constraint — Prisma generates where-key project_id_measure_type -->
    <addUniqueConstraint
      tableName="pafs_core_nfm_measures"
      columnNames="project_id, measure_type"
      constraintName="uq_nfm_measures_project_type"/>

    <rollback>
      <dropUniqueConstraint tableName="pafs_core_nfm_measures"
                            constraintName="uq_nfm_measures_project_type"/>
      <createIndex indexName="idx_nfm_measures_project_id"
                   tableName="pafs_core_nfm_measures">
        <column name="project_id"/>
      </createIndex>
    </rollback>
  </changeSet>

</databaseChangeLog>
