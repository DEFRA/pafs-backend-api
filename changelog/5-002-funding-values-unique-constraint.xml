<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

  <changeSet id="5-002-funding-values-unique-constraint" author="migration-team">
    <comment>
      Add unique constraint on (project_id, financial_year) in pafs_core_funding_values.
      Replaces the non-unique compound index with a proper unique constraint so Prisma
      can use a single upsert instead of findFirst + update/create.
      Each project can have multiple financial years; the constraint enforces one row per
      project per year. This changeset runs before data migration so the table is empty.
    </comment>

    <!-- Drop the existing non-unique compound index (replaced by the unique constraint below) -->
    <dropIndex indexName="funding_values_on_project_id_and_financial_year"
               tableName="pafs_core_funding_values"/>

    <!-- Add unique constraint — Prisma generates where-key project_id_financial_year -->
    <addUniqueConstraint
      tableName="pafs_core_funding_values"
      columnNames="project_id, financial_year"
      constraintName="uq_funding_values_project_year"/>

    <rollback>
      <dropUniqueConstraint tableName="pafs_core_funding_values"
                            constraintName="uq_funding_values_project_year"/>
      <createIndex indexName="funding_values_on_project_id_and_financial_year"
                   tableName="pafs_core_funding_values">
        <column name="project_id"/>
        <column name="financial_year"/>
      </createIndex>
    </rollback>
  </changeSet>

</databaseChangeLog>
